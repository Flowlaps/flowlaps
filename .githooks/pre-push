#!/usr/bin/env bash
set -euo pipefail

zero_sha="0000000000000000000000000000000000000000"
empty_tree="4b825dc642cb6eb9a060e54bf8d69288fbee4904"
remote_name="$1"

changed_files=""
diff_error=0
ref_count=0
single_local_sha=""
single_diff_base=""

while read -r local_ref local_sha remote_ref remote_sha; do
	[ -z "$local_sha" ] && continue
	[ "$local_sha" = "$zero_sha" ] && continue

	if [ "$remote_sha" = "$zero_sha" ]; then
		# New branch on the remote: diff against the merge-base with the
		# remote's default branch instead of the empty tree, otherwise every
		# file in the repo shows up as "changed".
		default_branch=$(git symbolic-ref --quiet --short "refs/remotes/$remote_name/HEAD" 2>/dev/null || true)
		base=""
		if [ -n "$default_branch" ]; then
			base=$(git merge-base "$default_branch" "$local_sha" 2>/dev/null || true)
		fi
		if [ -z "$base" ]; then
			for candidate in main master; do
				if git rev-parse --verify --quiet "refs/remotes/$remote_name/$candidate" >/dev/null; then
					base=$(git merge-base "refs/remotes/$remote_name/$candidate" "$local_sha" 2>/dev/null || true)
					[ -n "$base" ] && break
				fi
			done
		fi
		if [ -z "$base" ]; then
			echo "pre-push: warning: no merge-base found for new branch against $remote_name/{$default_branch,main,master} (shallow clone?); treating entire tree as new" >&2
		fi
		diff_base="${base:-$empty_tree}"
	else
		diff_base="$remote_sha"
	fi
	range="$diff_base..$local_sha"

	ref_count=$((ref_count + 1))
	single_local_sha="$local_sha"
	single_diff_base="$diff_base"

	stderr_file=$(mktemp)
	if files=$(git diff --name-only "$range" -- '*.ts' '*.tsx' '*.js' '*.jsx' 2>"$stderr_file"); then
		if [ -n "$files" ]; then
			changed_files="$changed_files
$files"
		fi
	else
		# Diff computation failed for a reason other than "no changes" (e.g.
		# stale/missing ref, shallow clone). Fail closed: we don't know what
		# changed, so we can't safely skip the review.
		echo "pre-push: warning: could not diff range '$range': $(cat "$stderr_file")" >&2
		diff_error=1
	fi
	rm -f "$stderr_file"
done

if [ "$diff_error" -ne 0 ]; then
	echo "pre-push: aborting push — could not determine which files changed, so the required review could not run. Investigate the warning above (e.g. run 'git fetch' to refresh remote refs), or use 'git push --no-verify' if you are certain no review is needed." >&2
	exit 1
fi

changed_files=$(printf '%s\n' "$changed_files" | sed '/^$/d' | sort -u)

if [ -z "$changed_files" ]; then
	exit 0
fi

review_timeout="${SCRUTINEER_TIMEOUT:-180}"

# scrutineer diffs a file's working tree against the git index (falling back
# to the full file when both are clean) — it has no way to target an
# arbitrary ref range. At pre-push time the working tree is normally clean,
# so without help scrutineer would review each file's entire current
# contents instead of the diff this push actually introduces. Point the
# index at the push's base tree instead, so scrutineer's own "index vs
# working tree" diff comes out equal to "base..local_sha" for each file.
# This only holds up for a single ref pushed from the currently checked-out
# branch — with multiple refs, or a ref other than HEAD, the working tree
# doesn't represent what's being pushed either way, so the trick is skipped
# and scrutineer falls back to its default (full-file) behavior.
use_index_trick=0
if [ "$ref_count" -eq 1 ]; then
	head_sha=$(git rev-parse --quiet --verify HEAD 2>/dev/null || true)
	if [ -n "$head_sha" ] && [ "$head_sha" = "$single_local_sha" ]; then
		use_index_trick=1
	fi
fi

tmp_index=""
cleanup() {
	[ -n "$tmp_index" ] && rm -f "$tmp_index"
}
trap cleanup EXIT

if [ "$use_index_trick" -eq 1 ]; then
	tmp_index=$(mktemp)
	if GIT_INDEX_FILE="$tmp_index" git read-tree "$single_diff_base" 2>/dev/null; then
		export GIT_INDEX_FILE="$tmp_index"
	else
		echo "pre-push: warning: could not build a diff index for $single_diff_base; scrutineer will review each file's full contents instead of the exact push diff" >&2
		rm -f "$tmp_index"
		tmp_index=""
	fi
else
	echo "pre-push: pushing multiple refs or a ref other than the current checkout; scrutineer will review each file's full contents instead of the exact push diff" >&2
fi

status=0
while IFS= read -r file; do
	[ -z "$file" ] && continue
	echo "pre-push: reviewing $file (timeout ${review_timeout}s)"
	timeout "$review_timeout" pnpm run review:local -- "$file" && rc=0 || rc=$?
	if [ "$rc" -ne 0 ]; then
		if [ "$rc" -eq 124 ]; then
			echo "pre-push: review of $file timed out after ${review_timeout}s (check that Ollama is reachable and the model is pulled, or network); failing closed" >&2
		fi
		status=1
	fi
done <<<"$changed_files"

exit "$status"

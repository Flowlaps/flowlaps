#!/usr/bin/env bash

echo "🔍 Running Scrutineer PR Review..."

# scrutineer's --diff flag now natively resolves the changed .ts/.tsx files
# against origin/main and batches them into one review call, replacing the
# manual per-file diff/loop logic this hook used to do itself. Note this
# reviews the whole branch's diff against main on every push (not just
# commits new since the last push), trading a bit of redundant local-only
# Ollama compute for a much simpler hook.
review_timeout="${SCRUTINEER_TIMEOUT:-180}"
timeout "$review_timeout" pnpm run review:local
RESULT=$?

if [ "$RESULT" -eq 124 ]; then
  echo "❌ Scrutineer review timed out after ${review_timeout}s (check that Ollama is reachable and the model is pulled)." >&2
  exit 1
fi

if [ "$RESULT" -ne 0 ]; then
  echo "❌ Scrutineer found issues. Push aborted."
  exit 1
fi

echo "✅ Scrutineer review passed. Pushing..."
exit 0
